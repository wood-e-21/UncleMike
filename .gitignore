# ─── Build artefacts ─────────────────────────────────────────────────
/target
/src-tauri/target
/frontend/.next
/frontend/out
/frontend/.turbo
/frontend/.swc
/frontend/node_modules

# Auto-generated by Tauri at build time (icons.rs, schemas/) — never
# hand-edited, regenerated on each `tauri dev|build`.
/src-tauri/gen

# TypeScript incremental build cache — wherever next/tsc drops it.
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# Rust coverage / profiling output.
*.profraw
coverage/

# ─── Local dev state — contains user data + secrets ──────────────────
.env
.env.local
**/.env.local
data/
.fastembed_cache/
# Alternative model-cache location pinned by ensure_fastembed_cache_dir
# when the user runs the binary outside the project root.
mikerust-data/

# ─── pdfium DLL ──────────────────────────────────────────────────────
# Prebuilt platform-specific binary; README documents how to fetch.
# We rule out both the root and the src-tauri copy because Tauri
# bundles its own search path under src-tauri/libs/.
libs/pdfium/
src-tauri/libs/pdfium/
# Downloaded archive used during initial setup (e.g.
# pdfium-win-arm64.tgz from the bblanchon repo).
pdfium-*.tgz
pdfium-*.zip

# ─── Editor / OS / dev residue ───────────────────────────────────────
.claude/
.vscode/
.idea/
*.log
*.swp
*.swo
*.orig
*.rej
.DS_Store
Thumbs.db

