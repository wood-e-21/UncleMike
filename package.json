{
  "name": "uncle-mike",
  "version": "0.1.0",
  "description": "Uncle Mike — sovereign local legal practice platform",
  "license": "AGPL-3.0-only",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n FRONTEND,ELECTRON -c blue,magenta \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:electron": "wait-on http://localhost:3000 && npm run build:electron && cross-env NODE_ENV=development electron .",
    "electron:lock-only": "npm run build:electron && cross-env NODE_ENV=development electron .",
    "install:all": "npm install && npm --prefix frontend install",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/copy-electron-assets.js",
    "build:frontend": "npm --prefix frontend run build && node scripts/stage-frontend.js",
    "build:backend": "cargo build -p mike-backend --release && node scripts/stage-backend.js",
    "build": "npm run build:electron && npm run build:backend && npm run build:frontend",
    "smoke:packaged-backend": "node scripts/packaged-backend-smoke.js",
    "dist": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac dir",
    "rebuild-native": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.unclemike.desktop",
    "productName": "Uncle Mike",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/.dist-bundle/mike-backend",
        "to": "backend/mike-backend"
      },
      {
        "from": "frontend/.next/standalone",
        "to": "frontend/.next/standalone"
      },
      {
        "from": "python/docling_sidecar",
        "to": "python/docling_sidecar",
        "filter": [
          "**/*",
          "!__pycache__",
          "!*.pyc"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "Mike-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "identity": null
    },
    "dmg": {
      "title": "Mike ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "hash-wasm": "^4.12.0"
  }
}
